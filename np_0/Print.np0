MODULE Print;

IMPORT Buffer, System;


PROCEDURE To(VAR buf : Buffer.Rec; file : INTEGER);

  VAR dummy : LONGINT;

  BEGIN
    System.GetInfo(buf.val[0], file);
    System.FileWrite(dummy, buf);
    Buffer.Reset(buf)
  END To;


PROCEDURE ToStderr*(VAR buf : Buffer.Rec);

  BEGIN
    To(buf, System.InfoStderr)
  END ToStderr;


PROCEDURE ToStdout*(VAR buf : Buffer.Rec);

  BEGIN
    To(buf, System.InfoStdout)
  END ToStdout;


END Print.
